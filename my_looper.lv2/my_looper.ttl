@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix pprops: <http://lv2plug.in/ns/ext/port-props#> .

<http://example.org/hybrid-looper>
    a lv2:Plugin ,
        lv2:DelayPlugin ;
    doap:name "Hybrid DJ Looper" ;
    doap:license <http://opensource.org/licenses/isc> ;
    lv2:port [
        # --- KNOB 1: TIME (0.0 a 1.0) ---
        a lv2:InputPort ,
            lv2:ControlPort ;
        lv2:index 0 ;
        lv2:symbol "time_step" ;
        lv2:name "Time" ;
        lv2:default 0.75 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
    ] , [
        # --- KNOB 2: FEEDBACK ---
        a lv2:InputPort ,
            lv2:ControlPort ;
        lv2:index 1 ;
        lv2:symbol "feedback" ;
        lv2:name "Feedback" ;
        lv2:default 0.8 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
    ] , [
        # --- KNOB 3: ACTIVATOR (Como Perilla/Knob para Superknobs) ---
        a lv2:InputPort ,
            lv2:ControlPort ;
        lv2:index 2 ;
        lv2:symbol "activator" ;
        lv2:name "Activator" ;
        lv2:default 0.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
    ] , [
        # --- KNOB 4: WET/DRY ---
        a lv2:InputPort ,
            lv2:ControlPort ;
        lv2:index 3 ;
        lv2:symbol "mix" ;
        lv2:name "Wet Dry" ;
        lv2:default 0.5 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
    ] , [
        # --- BOTON 1: HPF Filter ---
        a lv2:InputPort ,
            lv2:ControlPort ;
        lv2:index 4 ;
        lv2:symbol "hpf_enable" ;
        lv2:name "Filter HPF" ;
        lv2:default 0.0 ;
        lv2:minimum 0.0 ;
        lv2:maximum 1.0 ;
        lv2:portProperty lv2:toggled ; # Mixxx lo dibuja como botón
    ] , [
        # --- PUERTO INVISIBLE DE BPM (Sincronización oculta) ---
        a lv2:InputPort ,
            lv2:ControlPort ;
        lv2:index 5 ;
        lv2:symbol "bpm" ;
        lv2:name "BPM" ;
        lv2:default 120.0 ;
        lv2:minimum 40.0 ;
        lv2:maximum 250.0 ;
        lv2:designation <http://lv2plug.in/ns/ext/time#beatsPerMinute> ;
        lv2:portProperty lv2:connectionOptional , pprops:notOnGUI ; # No se dibuja en la pantalla
    ] , [
        # --- AUDIO PORTS ---
        a lv2:AudioPort ,
            lv2:InputPort ;
        lv2:index 6 ;
        lv2:symbol "in_left" ;
        lv2:name "In Left"
    ] , [
        a lv2:AudioPort ,
            lv2:InputPort ;
        lv2:index 7 ;
        lv2:symbol "in_right" ;
        lv2:name "In Right"
    ] , [
        a lv2:AudioPort ,
            lv2:OutputPort ;
        lv2:index 8 ;
        lv2:symbol "out_left" ;
        lv2:name "Out Left"
    ] , [
        a lv2:AudioPort ,
            lv2:OutputPort ;
        lv2:index 9 ;
        lv2:symbol "out_right" ;
        lv2:name "Out Right"
    ] .
